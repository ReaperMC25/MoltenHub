UtilityTab:CreateSection("Alt Balant")

local function getServerPlayers()
    local list = {}
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= player then table.insert(list, p.Name) end
    end
    if #list == 0 then table.insert(list, "No players found") end
    return list
end

local altBalantDropdown = UtilityTab:CreateDropdown({
    Name = "👥 Alt Balant Player List",
    Options = getServerPlayers(),
    CurrentOption = {""},
    MultipleOptions = false,
    Flag = "AltBalantTarget",
    Callback = function(selected)
        altBalantTarget = type(selected) == "table" and (selected[1] or "") or (selected or "")
    end,
})

UtilityTab:CreateButton({
    Name = "🔄 Refresh Player List",
    Callback = function()
        local newList = getServerPlayers()
        altBalantDropdown:Refresh(newList, true)
        Rayfield:Notify({ Title="Alt Balant", Content="Refreshed! ("..#newList.." players)", Duration=2, Image=4483362458 })
    end,
})

UtilityTab:CreateToggle({
    Name = "💥 Alt Balant", CurrentValue = false, Flag = "AltBalant",
    Callback = function(val)
        altBalantActive = val
        if val then
            if altBalantTarget == "" or altBalantTarget == "No players found" then
                Rayfield:Notify({ Title="Alt Balant", Content="Select a target first!", Duration=3, Image=4483362458 })
                altBalantActive = false return
            end
            altBalantBusy = false
            task.spawn(function()
                while altBalantActive do
                    if not altBalantBusy then
                        altBalantBusy = true
                        local char   = player.Character
                        local myHRP  = char and char:FindFirstChild("HumanoidRootPart")
                        local tgt    = Players:FindFirstChild(altBalantTarget)
                        local tgtHRP = tgt and tgt.Character and tgt.Character:FindFirstChild("HumanoidRootPart")
                        if myHRP and tgtHRP then
                            myHRP.CFrame = tgtHRP.CFrame * CFrame.new(0,0,-2)
                            task.wait(2)
                            if altBalantActive then
                                player:LoadCharacter()
                                player.CharacterAdded:Wait()
                                task.wait(0.5)
                            end
                        else
                            task.wait(0.5)
                        end
                        altBalantBusy = false
                    end
                    task.wait(0.1)
                end
            end)
            Rayfield:Notify({ Title="Alt Balant", Content="Locked onto: "..altBalantTarget.." 🔥", Duration=3, Image=4483362458 })
        else
            altBalantBusy = false
            Rayfield:Notify({ Title="Alt Balant", Content="Disabled.", Duration=2, Image=4483362458 })
        end
    end,
})

-- ══════════════════════════════════════════
--  XCZ Function
-- ══════════════════════════════════════════
local function doXCZ()
    if xczCooldown then return end
    xczCooldown = true
    local char = player.Character
    if not char then xczCooldown = false return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then xczCooldown = false return end
    VirtualInputManager:SendKeyEvent(true,  Enum.KeyCode.Four, false, game) task.wait(0.05)
    VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.Four, false, game) task.wait(0.1)
    VirtualInputManager:SendKeyEvent(true,  Enum.KeyCode.W,    false, game) task.wait(0.01)
    VirtualInputManager:SendKeyEvent(true,  Enum.KeyCode.Q,    false, game) task.wait(0.03)
    VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.Q,    false, game) task.wait(0.04)
    hrp.CFrame = hrp.CFrame * CFrame.Angles(0, math.pi, 0) task.wait(0.03)
    VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.W,    false, game) task.wait(0.05)
    VirtualInputManager:SendKeyEvent(true,  Enum.KeyCode.One,  false, game) task.wait(0.02)
    VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.One,  false, game) task.wait(0.5)
    xczCooldown = false
end

UserInputService.InputBegan:Connect(function(input, gp)
    if gp then return end
    if input.KeyCode == Enum.KeyCode.E and xczEnabled then task.spawn(doXCZ) end
end)

