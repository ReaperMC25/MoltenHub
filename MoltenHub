                local c = Players.LocalPlayer.Character
                if not c or not c:FindFirstChild("HumanoidRootPart") then return end
                local region = Region3.new(
                    c.HumanoidRootPart.Position - Vector3.new(20,20,20),
                    c.HumanoidRootPart.Position + Vector3.new(20,20,20)
                )
                for _, part in ipairs(workspace:FindPartsInRegion3(region,nil,math.huge)) do
                    local hum = part.Parent:FindFirstChildOfClass("Humanoid")
                    if hum and hum.Health <= 0 and not processedHumanoids[hum] then
                        defeatedCount = defeatedCount + 1
                        processedHumanoids[hum] = true
                    end
                end
            end

            local function spamMove(remote)
                if not canUseMove then return end
                local st = tick()
                while tick()-st < SPAM_DURATION do
                    remote:FireServer(unpack(moveArgs))
                    task.wait(SPAM_INTERVAL)
                end
                task.wait(TIME_AFTER_SPAM)
                resetPlayer()
            end

            local function setupCharacter(character)
                local hrp    = character:WaitForChild("HumanoidRootPart",10)
                local remote = character:WaitForChild("Communicate",10)
                local bp     = Players.LocalPlayer:WaitForChild("Backpack",10)
                if not hrp or not remote or not bp then return end
                local moveTool = bp:FindFirstChild(SELECTED_MOVE)
                while not moveTool do task.wait(1) moveTool = bp:FindFirstChild(SELECTED_MOVE) end
                moveArgs = {[1]={["Tool"]=moveTool,["Goal"]="Console Move",["ToolName"]=SELECTED_MOVE}}
                canUseMove = false
                task.wait(TIME_AFTER_SPAWN)
                canUseMove = true
                task.spawn(function()
                    while character and character.Parent do
                        countDefeated()
                        if defeatedCount >= 2 and canUseMove then
                            spamMove(remote)
                            defeatedCount = 0
                            table.clear(processedHumanoids)
                            canUseMove = false
                            task.wait(TIME_AFTER_SPAWN)
                            canUseMove = true
                        end
                        task.wait(1)
                    end
                end)
            end

            Players.LocalPlayer.CharacterAdded:Connect(setupCharacter)
            if Players.LocalPlayer.Character then setupCharacter(Players.LocalPlayer.Character) end

            task.wait(10)
            local c = Players.LocalPlayer.Character
            if c and c:FindFirstChild("Humanoid") then c.Humanoid.Health = 0 end

            Rayfield:Notify({ Title="Main Farm", Content="✅ Running! GUI + Farm active.", Duration=4, Image=4483362458 })
        end)
    end,
})

