task.spawn(function()
    while true do
        if keySpam then
            for _, k in ipairs({Enum.KeyCode.One,Enum.KeyCode.Two,Enum.KeyCode.Three,Enum.KeyCode.Four}) do
                if not keySpam then break end
                VirtualInputManager:SendKeyEvent(true,  k, false, game) task.wait(0.02)
                VirtualInputManager:SendKeyEvent(false, k, false, game) task.wait(spamDelay)
            end
        else
            task.wait(0.05)
        end
    end
end)

