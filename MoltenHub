                        if c and c:FindFirstChild("Communicate") then
                            c.Communicate:FireServer(unpack(args))
                        end
                        task.wait(3)
                    end
                end
                local function onCharAdded(char)
                    if _G.spinThread then pcall(function() coroutine.close(_G.spinThread) end) end
                    _G.spinThread = coroutine.create(spinEmote)
                    coroutine.resume(_G.spinThread)
                end
                Players.LocalPlayer.CharacterAdded:Connect(onCharAdded)
                if Players.LocalPlayer.Character then onCharAdded(Players.LocalPlayer.Character) end
            end

