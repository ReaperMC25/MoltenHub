                    chkBox.BackgroundColor3 = isSelected and Color3.fromRGB(60,130,255) or Color3.fromRGB(35,35,65)
                    chkBox.BorderSizePixel = 0 chkBox.ZIndex = 18
                    Instance.new("UICorner",chkBox).CornerRadius = UDim.new(0,4)
                    local chkTick = Instance.new("TextLabel",chkBox)
                    chkTick.Size = UDim2.fromScale(1,1)
                    chkTick.BackgroundTransparency = 1
                    chkTick.Text = isSelected and "✔" or ""
                    chkTick.TextColor3 = Color3.fromRGB(255,255,255)
                    chkTick.TextSize = 11 chkTick.Font = Enum.Font.GothamBold
                    chkTick.ZIndex = 19

                    -- player name label
                    local nameLbl = Instance.new("TextLabel",row)
                    nameLbl.Size = UDim2.new(1,-36,1,0)
                    nameLbl.Position = UDim2.new(0,32,0,0)
                    nameLbl.BackgroundTransparency = 1
                    nameLbl.Font = Enum.Font.Gotham
                    nameLbl.Text = p.Name.."  ("..p.UserId..")"
                    nameLbl.TextColor3 = isSelected and Color3.fromRGB(155,210,255) or Color3.fromRGB(130,150,200)
                    nameLbl.TextSize = 12
                    nameLbl.TextXAlignment = Enum.TextXAlignment.Left
                    nameLbl.ZIndex = 18

                    -- click to toggle selection
                    local clickBtn = Instance.new("TextButton",row)
                    clickBtn.Size = UDim2.fromScale(1,1)
                    clickBtn.BackgroundTransparency = 1
                    clickBtn.Text = "" clickBtn.ZIndex = 20
                    clickBtn.MouseButton1Click:Connect(function()
                        if selectedTargets[p.UserId] then
                            selectedTargets[p.UserId] = nil
                        else
                            selectedTargets[p.UserId] = p.Name
                        end
                        refreshSavedLbl()
                        updatePList() -- redraw with new state
                    end)
                end
                scrollF.CanvasSize = UDim2.new(0,0,0,#plrs*34+4)
            end

            -- Select All
            selAllB.MouseButton1Click:Connect(function()
                for _, p in pairs(Players:GetPlayers()) do
                    selectedTargets[p.UserId] = p.Name
                end
                refreshSavedLbl()
                updatePList()
            end)

            -- Clear All
            clearAllB.MouseButton1Click:Connect(function()
                table.clear(selectedTargets)
                refreshSavedLbl()
                updatePList()
            end)

            Players.PlayerAdded:Connect(function() if plFrame.Visible then updatePList() end end)
            Players.PlayerRemoving:Connect(function(p)
                selectedTargets[p.UserId] = nil
                refreshSavedLbl()
                if plFrame.Visible then updatePList() end
            end)

            -- Open player selector
            menuB.MouseButton1Click:Connect(function()
                plFrame.Visible = true
                updatePList()
            end)

            -- Start / Stop toggle
            toggleB.MouseButton1Click:Connect(function()
                if getSelectedCount() == 0 then
                    GuiSvc:SetCore("SendNotification", {Title="Alt Farm", Text="Select at least one player first!"})
                    return
                end
                isScriptActive = not isScriptActive
                if isScriptActive then
                    toggleB.Text = "■  Stop Alt Farm Script"
                    toggleB.BackgroundColor3 = Color3.fromRGB(175,28,28)
                    statusLbl.Text = "● ACTIVE"
                    statusLbl.TextColor3 = Color3.fromRGB(75,215,115)
                    statusBadge.BackgroundColor3 = Color3.fromRGB(8,26,8)
                    sStroke.Color = Color3.fromRGB(55,195,95)
                    if not monitorCoro or coroutine.status(monitorCoro) == "dead" then
                        monitorCoro = coroutine.create(function() pcall(monitorTarget) end)
                        coroutine.resume(monitorCoro)
                    end
                    local n = getSelectedCount()
                    GuiSvc:SetCore("SendNotification", {Title="Alt Farm", Text="🔥 Farming "..n.." player"..(n==1 and "" or "s").."!"})
                else
                    toggleB.Text = "▶  Start Alt Farm Script"
                    toggleB.BackgroundColor3 = Color3.fromRGB(28,55,195)
                    statusLbl.Text = "● IDLE"
                    statusLbl.TextColor3 = Color3.fromRGB(110,110,170)
                    statusBadge.BackgroundColor3 = Color3.fromRGB(18,18,28)
                    sStroke.Color = Color3.fromRGB(70,70,170)
                    GuiSvc:SetCore("SendNotification", {Title="Alt Farm", Text="Stopped."})
                end
            end)

            refreshSavedLbl()

            -- Slide-in animation
            mf.BackgroundTransparency = 1
            TweenService:Create(mf, TweenInfo.new(0.45,Enum.EasingStyle.Back,Enum.EasingDirection.Out), {
                Position = UDim2.new(0.5,0,0.5,0),
                BackgroundTransparency = 0
            }):Play()

            GuiSvc:SetCore("SendNotification", {Title="Alt Farm", Text="✅ GUI + background systems running!", Duration=4})
        end)
    end,
})

