                    initialKillsValue = kills.Value
                    totalKills = initialKillsValue
                    initialKillsRecorded = true
                end
                while true do
                    if kills and kills.Value then
                        totalKills = kills.Value
                        if totalKills >= initialKillsValue + ADDITIONAL_KILLS then
