            local function reconnectToServer()
                if totalKills >= MAX_TOTAL_KILLS then closeGame() return end
                local cjid = game.JobId
                if cjid then
                    TeleService:TeleportToPlaceInstance(game.PlaceId, cjid, Players.LocalPlayer)
                    task.wait(5)
                end
                TeleService:Teleport(game.PlaceId)
            end

            -- Kill tracker
            task.spawn(function()
